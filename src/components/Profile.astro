---
import { Image } from "astro:assets";
import profilePic from "../assets/profile-pic.JPG";

interface Props {
  extraClasses?: string;
}

const { extraClasses = "" } = Astro.props;

const name = "Kuldeep Yadav";
const shortIntro = "I know few things about coding";
const twitter = "marzi_ka_maalik";
const github = "novicedev7291";
---

<div class={`flex items-center space-x-4 p-4 ${extraClasses}`}>
  <Image
    class="rounded-full"
    src={profilePic}
    width={100}
    height={100}
    alt="profile-pic"
  />
  <div class="flex flex-col flex-grow justify-center">
    <p class="font-medium text-gray-700 text-md">{name}</p>
    <strong class="text-gray-600 italic text-sm">{shortIntro}</strong>
    <div class="flex mt-2">
      <a href={`https://x.com/${twitter}`}>
        <img
          src="https://simpleicons.org/icons/x.svg"
          alt="my-twitter"
          class="mr-2 mb-0 w-5"
        />
      </a>
      <a href={`https://github.com/${github}`}>
        <img
          src="https://simpleicons.org/icons/github.svg"
          alt="my-github"
          class="ml-2 mb-0 w-5"
        />
      </a>
    </div>
  </div>
</div>

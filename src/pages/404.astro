---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 Not Found">
  <div class="flex flex-col items-center justify-center min-h-64 space-y-4">
    <h1 class="text-4xl font-bold text-gray-700">404: Not Found</h1>
    <p class="text-gray-600">You just hit a route that doesn't exist... the sadness.</p>
    <a class="text-gray-600 font-semibold text-sm" href="/">&larr; Go back home</a>
  </div>
</Layout>
